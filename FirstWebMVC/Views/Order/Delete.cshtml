@model FirstWebMVC.Models.Entities.Order

@{
    ViewData["Title"] = "Xóa đơn hàng";
}

<h2>Xóa đơn hàng</h2>

<h4>Bạn có chắc muốn xóa không?</h4>

<div>
    <p><strong>Mã đơn:</strong> @Model.OrderId</p>
    <p><strong>Khách hàng:</strong> @Model.Customer?.Name</p>
    <p><strong>Ngày:</strong> @Model.OrderDate.ToString("dd/MM/yyyy")</p>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="OrderId" />

    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>