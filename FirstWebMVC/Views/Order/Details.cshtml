@model FirstWebMVC.Models.Entities.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<h2>Chi tiết đơn hàng</h2>

<div>
    <p><strong>Mã đơn:</strong> @Model.OrderId</p>
    <p><strong>Khách hàng:</strong> @Model.Customer?.Name</p>
    <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy")</p>
</div>

<h4>Danh sách sản phẩm</h4>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Sản phẩm</th>
            <th>Số lượng</th>
            <th>Giá</th>
            <th>Thành tiền</th>
        </tr>
    </thead>
    <tbody>
@{
    decimal total = 0;
}

@foreach (var item in Model.OrderDetails)
{
    var thanhTien = item.Quantity * item.Price;
    total += thanhTien;

    <tr>
        <td>@item.Product?.ProductName</td>
        <td>@item.Quantity</td>
        <td>@item.Price</td>
        <td>@thanhTien</td>
    </tr>
}

<tr>
    <td colspan="3"><strong>Tổng tiền</strong></td>
    <td><strong>@total</strong></td>
</tr>

    </tbody>
</table>

<p>
    <a asp-action="Edit" asp-route-id="@Model.OrderId">Sửa</a> |
    <a asp-action="Index">Quay lại</a>
</p>