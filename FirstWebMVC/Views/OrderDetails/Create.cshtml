@model FirstWebMVC.Models.Entities.OrderDetail

@{
    ViewData["Title"] = "Thêm chi tiết đơn hàng";
}

<h2>Thêm chi tiết đơn hàng</h2>

<form asp-action="Create">

    <div class="form-group">
        <label>Đơn hàng</label>
        <select asp-for="OrderId" asp-items="ViewBag.OrderId" class="form-control"></select>
    </div>

    <div class="form-group">
        <label>Sản phẩm</label>
        <select asp-for="ProductId" asp-items="ViewBag.ProductId" class="form-control"></select>
    </div>

    <div class="form-group">
        <label>Số lượng</label>
        <input asp-for="Quantity" class="form-control" />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Giá</label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <br />
    <button type="submit" class="btn btn-success">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>