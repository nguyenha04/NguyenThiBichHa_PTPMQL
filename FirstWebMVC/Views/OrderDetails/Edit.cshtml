@model FirstWebMVC.Models.Entities.OrderDetail

@{
    ViewData["Title"] = "Sửa chi tiết đơn hàng";
}

<h2>Sửa chi tiết đơn hàng</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="OrderDetailId" />

    <div class="form-group">
        <label>Đơn hàng</label>
        <select asp-for="OrderId" asp-items="ViewBag.OrderId" class="form-control"></select>
    </div>

    <div class="form-group">
        <label>Sản phẩm</label>
        <select asp-for="ProductId" asp-items="ViewBag.ProductId" class="form-control"></select>
    </div>

    <div class="form-group">
        <label>Số lượng</label>
        <input asp-for="Quantity" class="form-control" />
    </div>

    <div class="form-group">
        <label>Giá</label>
        <input asp-for="Price" class="form-control" />
    </div>

    <br />
    <button type="submit" class="btn btn-primary">Cập nhật</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>